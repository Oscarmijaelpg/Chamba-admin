# Chamba Admin Panel Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API Configuration
VITE_API_URL=http://localhost:5000
VITE_API_TIMEOUT=30000

# Application Configuration
VITE_APP_NAME=Chamba
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Admin Panel for Chamba Platform

# Environment (development, staging, production)
VITE_ENV=development

# Feature Flags
VITE_FEATURE_E2E_TESTING=true
VITE_FEATURE_API_DOCS=true
VITE_FEATURE_ANALYTICS=false
VITE_FEATURE_DEBUG_PANEL=true

# Debugging
VITE_DEBUG=false
VITE_DEBUG_SQL=false
VITE_DEBUG_API=false

# Security
VITE_API_SECURE=true
